# ==========================================
# AIStarter 环境变量配置模板
# 使用说明：请复制此文件并重命名为 .env，然后填入你的真实参数
# 警告：绝不要将包含真实密钥的 .env 文件提交到版本控制系统中！
# ==========================================

# 基础服务配置
NODE_ENV=development
PORT=3000

# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=aistarter_db

# 身份验证 (JWT)
JWT_SECRET=your_jwt_secret_key_here

# 阿里云 OSS 存储配置 (用于文件/图片上传)
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=

# 邮件服务配置 (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# ==========================================
# 第三方支付 SDK 配置 (如不使用可留空)
# ==========================================

# 支付宝配置
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 微信支付配置
WECHAT_PAY_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=

# Stripe (国际信用卡) 配置
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal 配置
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=