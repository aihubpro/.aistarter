{
  "name": "AIStarter",
  "private": true,
  "version": "5.2.0",
  "description": "AI Starter",
  "main": "app/main.js",
  "author": "Your Name",
  "email": "you@example.com",
  "homepage": "https://github.com/YOUR_USERNAME/YOUR_REPO",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build": "vite build",
    "generate": "vite-ssg build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "dist": "electron-builder",
    "dist:arm64":"electron-builder --arm64",
    "extract":"node extractFiles.js"
  },
  "build": {
    "appId": "com.yourcompany.aistarter",
    "productName": "AIStarter",
    "copyright": "Your Company Copyright",
    "compression": "maximum",
    "files": [
      "app/**/*"
    ],
    "win": {
      "publisherName": "Your Name",
      "icon": "src/assets/icon.ico",
      "target": [
        "nsis"
      ],
      "legalTrademarks": "AIStarter",
      "publish": {
        "provider": "generic",
        "url": ""
      },
      "verifyUpdateCodeSignature": false,
      "signingHashAlgorithms": [
        "sha1"
      ],
      "signDlls": true,
      "rfc3161TimeStampServer": "http://timestamp.comodoca.com/authenticode",
      "certificateFile": "./doc/your-certificate.pfx",
      "certificatePassword": "__CERTIFICATE_PASSWORD_PLACEHOLDER__"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "installerSidebar": "./assets/installerSiddebar.bmp",
      "uninstallerSidebar": "./assets/uninstallerSiddebar.bmp",
      "license": "./public/license.txt"
    },
    "mac": {
      "asar": true,
      "asarUnpack": [
        "**/node_modules/@img/**"
      ],
      "target": {
        "target": "dmg"
      },
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "asar": true,
      "asarUnpack": [
        "**/node_modules/@img/**"
      ],
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "maintainer": "Your Name <you@example.com>",
      "category": "Utility",
      "icon": "assets/icon.icns"
    }
  },
  "dependencies": {
    "node-downloader-helper": "^2.1.9",
    "undraw-ui": "^1.3.5",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@element-plus/icons-vue": "^2.3.1",
    "@vueuse/core": "^10.11.0",
    "ali-oss": "^6.21.0",
    "archiver": "7.0.1",
    "axios": "^1.7.2",
    "bytenode": "1.5.6",
    "codemirror": "^6.0.1",
    "decompress-zip": "^0.3.3",
    "dom-to-image": "^2.6.0",
    "ejs": "^3.1.10",
    "electron-download-manager": "^2.1.2",
    "electron-updater": "^6.2.1",
    "element-plus": "^2.7.6",
    "form-data": "^4.0.0",
    "iconv-lite": "^0.6.3",
    "node-machine-id": "^1.1.12",
    "node-stream-zip": "^1.15.0",
    "pinia": "^2.2.2",
    "prettier-bytes": "1.0.4",
    "progress-stream": "^2.0.0",
    "readable-stream": "4.5.2",
    "sharp": "^0.34.2",
    "tar": "^7.4.3",
    "vue": "^3.4.30",
    "vue-codemirror": "^6.1.1",
    "vue-i18n": "^9.13.1",
    "vue-matomo": "^4.2.0",
    "vue-qrcode": "^2.2.2",
    "vue-router": "^4.4.0",
    "vue-web-terminal": "3.2.5",
    "webtorrent": "1.9.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@iconify-json/ep": "^1.1.15",
    "@types/codemirror": "^5.60.15",
    "@types/node": "^20.14.9",
    "@vitejs/plugin-vue": "^5.0.5",
    "electron": "29.0.0",
    "electron-builder": "^24.13.3",
    "sass": "^1.77.6",
    "typescript": "^5.5.2",
    "unocss": "^0.58.8",
    "unplugin-vue-components": "^0.27.2",
    "vite": "^5.3.2",
    "vite-ssg": "^0.23.7",
    "vue-tsc": "^2.0.22"
  },
  "license": "MIT"
}
